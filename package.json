    "i18next-http-backend": "^2.4.2",
    "immer": "^10.0.3",
    "qs": "^6.11.2",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
